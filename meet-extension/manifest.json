{
  "manifest_version": 3,
  "name": "Luna 2.0 Meet Injector",
  "version": "1.0",
  "description": "Integrates the Luna 2.0 Companion directly into Google Meet calls as a participant.",
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["calendar-content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "permissions": ["activeTab"],
  "web_accessible_resources": [
    {
      "resources": ["orb-injector.js"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}
